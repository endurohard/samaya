NODE_ENV=development

POSTGRES_USER=samaya
POSTGRES_PASSWORD=samaya_dev_secret
POSTGRES_DB=samaya

REDIS_URL=redis://redis:6379

JWT_SECRET=please_change_me_in_production_with_a_64_byte_random_value
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Хост-порты Kong. По умолчанию 8010/8011, чтобы не конфликтовать с другими
# проектами на 8000/8001 (например, food-flow). Внутри сети kong всё равно слушает 8000.
KONG_PROXY_PORT=8010
KONG_ADMIN_PORT=8011

# Frontend (admin SPA на nginx). Открыть http://localhost:${FRONTEND_PORT}.
FRONTEND_PORT=3010

# Сид-компания (Самая) — детерминированный UUID, создаётся миграцией 001_users.sql.
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000001
DEFAULT_COMPANY_SLUG=samaya
LOG_LEVEL=info
